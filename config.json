{
  "log_file": "./envCheck.log",
  "output_format": "text",
  "paths": [
    "$HOME/.kube",
    "/etc/kubernetes",
    "/usr/bin/kube*",
    "/usr/local/bin/kube*",
    "/usr/local/bin/crictl",
    "/etc/sysctl.d/k8s.conf",
    "/etc/systemd/system/kubelet.service",
    "/etc/systemd/system/kubelet.service.d",
    "/var/lib/etcd",
    "/var/lib/kubelet",
    "/run/containerd/containerd.sock",
    "/usr/lib/systemd/system/kubelet.service.d",
    "/var/run/containerd/containerd.sock",
    "/var/run/docker.sock"
  ],
  "clean_force": false,
  "program_list": [
    "docker",
    "kubectl",
    "containerd"
  ],
  "hosts": [
    {
      "ip": "192.168.2.135",
      "username": "root",
      "password": "Beyond#11",
      "port": "22",
      "role": ["bootstrap"]
    },
    {
      "ip": "192.168.2.221",
      "username": "root",
      "password": "Beyond#11",
      "port": "22",
      "role": ["master"]
    },
    {
      "ip": "192.168.2.229",
      "username": "root",
      "password": "Beyond#11",
      "port": "22",
      "role": ["worker"]
    }
  ],
  "clock_threshold": 10,
  "kernel_check": {
    "min_version": "4.18",
    "operator": ">="
  },
  "port_check": {
    "ports": {
      "bootstrap": ["36443", "40080", "40443", "38080"],
      "master": ["6443", "30029", "30909", "30903", "3030", "30019", "9012"],
      "worker": ["10250", "10256", "30000", "30001", "30022", "30033", "30024"]
    },
    "timeout": 10
  },
  "disk_check": {
    "check_items": [
      {"path": "/", "min_free_gb": 50},
      {"path": "/var/lib", "min_free_gb": 50},
      {"path": "/var/run", "min_free_gb": 50}
    ]
  },
  "dispatch": {
    "timeout": 600,
    "poll_interval": 15,
    "work_dir": "/tmp/envcheck",
    "concurrent_limit": 10
  }
}
